---
import BaseHead from "../components/BaseHead.astro";

interface Props {
	title: string;
	active?: "posts" | "new";
}

const { title, active = "posts" } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={`${title} - CMS Blog Aruna JR`} description="CMS internal untuk mengelola artikel blog Aruna JR." />
		<style>
			:root {
				--cms-bg: #f4f6fb;
				--cms-panel: #ffffff;
				--cms-line: #dbe2ee;
				--cms-muted: #64748b;
				--cms-text: #172033;
				--cms-dark: #20283a;
				--cms-blue: #4f65e8;
				--cms-blue-soft: #eef2ff;
				--cms-green: #177245;
				--cms-yellow: #8a4b00;
				--cms-red: #b42318;
			}

			body {
				background: var(--cms-bg);
				color: var(--cms-text);
			}

			main {
				width: 1240px;
				max-width: calc(100% - 2rem);
				padding: 2.4rem 1rem;
			}

			.admin-shell {
				display: grid;
				grid-template-columns: minmax(230px, 275px) minmax(0, 1fr);
				gap: 1.5rem;
			}

			.admin-panel {
				background: var(--cms-panel);
				border: 1px solid var(--cms-line);
				border-radius: 12px;
				box-shadow: 0 14px 36px rgba(31, 41, 55, 0.08);
			}

			.admin-sidebar {
				align-self: start;
				overflow: hidden;
			}

			.brand-block {
				padding: 1.35rem 1.35rem 1.15rem;
				border-bottom: 1px solid var(--cms-line);
			}

			.brand-block h1 {
				margin: 0;
				font-size: 1rem;
				line-height: 1.3;
				font-weight: 650;
			}

			.brand-block p,
			.page-subtitle,
			.form-hint,
			.status,
			.upload-meta,
			.post-meta {
				margin: 0.25rem 0 0;
				color: var(--cms-muted);
				font-size: 0.86rem;
				line-height: 1.5;
			}

			.nav-group {
				padding: 1rem;
			}

			.nav-title {
				display: block;
				margin: 0 0 0.45rem;
				color: var(--cms-muted);
				font-size: 0.78rem;
				font-weight: 650;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}

			.nav-link {
				display: flex;
				align-items: center;
				justify-content: space-between;
				border-radius: 9px;
				padding: 0.7rem 0.8rem;
				color: var(--cms-text);
				text-decoration: none;
				font-weight: 500;
			}

			.nav-link:hover,
			.nav-link.is-active {
				background: var(--cms-blue-soft);
				color: var(--cms-blue);
			}

			.page-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 1.35rem 1.5rem;
				border-bottom: 1px solid var(--cms-line);
			}

			.page-header h2 {
				margin: 0;
				font-size: 1.35rem;
				line-height: 1.25;
				font-weight: 650;
			}

			button,
			.button,
			.file-button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				border: 0;
				border-radius: 9px;
				padding: 0.68rem 0.9rem;
				background: var(--cms-blue);
				color: #fff;
				font: inherit;
				font-weight: 600;
				text-decoration: none;
				cursor: pointer;
			}

			button.secondary,
			.button.secondary,
			.file-button {
				background: var(--cms-dark);
			}

			button.ghost,
			.button.ghost {
				background: transparent;
				color: var(--cms-blue);
			}

			button:disabled {
				opacity: 0.55;
				cursor: not-allowed;
			}

			.badge {
				display: inline-flex;
				align-items: center;
				width: max-content;
				border-radius: 999px;
				padding: 0.15rem 0.5rem;
				background: #e7f8ee;
				color: var(--cms-green);
				font-size: 0.74rem;
				font-weight: 650;
			}

			.badge.is-draft {
				background: #fff2d6;
				color: var(--cms-yellow);
			}

			.status.is-error {
				color: var(--cms-red);
			}

			@media (max-width: 900px) {
				main {
					max-width: calc(100% - 1rem);
					padding: 1rem 0.5rem;
				}

				.admin-shell {
					grid-template-columns: 1fr;
					gap: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<div class="admin-shell">
				<aside class="admin-panel admin-sidebar">
					<div class="brand-block">
						<h1>CMS Blog</h1>
						<p>Kelola artikel arunajr.com</p>
					</div>
					<nav class="nav-group" aria-label="Menu admin">
						<span class="nav-title">Posts</span>
						<a class={`nav-link${active === "posts" ? " is-active" : ""}`} href="/admin/posts">All Posts</a>
						<a class={`nav-link${active === "new" ? " is-active" : ""}`} href="/admin/posts/new">Add New</a>
					</nav>
				</aside>
				<section class="admin-panel">
					<slot />
				</section>
			</div>
		</main>
	</body>
</html>
