---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`404 Not Found - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main style="text-align: center; padding: 6em 1em; display: flex; flex-direction: column; align-items: center;">
			<img src="/favicon.webp" alt="404 Icon" width="100" style="margin-bottom: 2rem;" />
			
			<h1 style="font-size: 3rem; margin-bottom: 0.5rem;">404</h1>
			<h2>Halaman Tidak Ditemukan</h2>
			<p style="margin-bottom: 2rem;">Maaf, halaman yang Anda cari tidak ada atau sudah dipindahkan.</p>
			
			<a class="pastel-btn" href="/">Kembali ke Home</a>
		</main>
		<Footer />
	</body>
</html>