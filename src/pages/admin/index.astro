---
import BaseHead from "../../components/BaseHead.astro";
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title="CMS Blog - Aruna JR" description="CMS internal untuk mengelola artikel blog Aruna JR." />
		<style>
			:root {
				--cms-bg: #f4f6fb;
				--cms-panel: #ffffff;
				--cms-line: #dbe2ee;
				--cms-muted: #64748b;
				--cms-text: #172033;
				--cms-dark: #20283a;
				--cms-blue: #4f65e8;
				--cms-blue-soft: #eef2ff;
				--cms-green: #177245;
				--cms-yellow: #8a4b00;
			}

			body {
				background: var(--cms-bg);
				color: var(--cms-text);
			}

			main {
				width: 1180px;
				max-width: calc(100% - 2rem);
				padding: 2rem 1rem;
			}

			.admin-shell {
				display: grid;
				grid-template-columns: minmax(230px, 280px) minmax(0, 1fr);
				gap: 1rem;
			}

			.admin-panel {
				background: var(--cms-panel);
				border: 1px solid var(--cms-line);
				border-radius: 12px;
				box-shadow: 0 14px 36px rgba(31, 41, 55, 0.08);
			}

			.admin-sidebar {
				align-self: start;
				overflow: hidden;
			}

			.brand-block {
				padding: 1rem 1rem 0.85rem;
				border-bottom: 1px solid var(--cms-line);
			}

			.brand-block h1,
			.editor-toolbar h2 {
				margin: 0;
				font-size: 1rem;
				line-height: 1.3;
				font-weight: 650;
				letter-spacing: -0.01em;
			}

			.brand-block p,
			.editor-toolbar p,
			.form-hint,
			.status,
			.upload-meta {
				margin: 0.25rem 0 0;
				color: var(--cms-muted);
				font-size: 0.86rem;
				line-height: 1.5;
			}

			.nav-group {
				padding: 0.75rem;
				border-bottom: 1px solid var(--cms-line);
			}

			.nav-title {
				display: block;
				margin: 0 0 0.45rem;
				color: var(--cms-muted);
				font-size: 0.78rem;
				font-weight: 650;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}

			.nav-button,
			.post-button,
			button,
			.file-button {
				font: inherit;
				cursor: pointer;
			}

			.nav-button {
				display: flex;
				align-items: center;
				justify-content: space-between;
				width: 100%;
				border: 0;
				border-radius: 9px;
				padding: 0.58rem 0.7rem;
				background: transparent;
				color: var(--cms-text);
				text-align: left;
				font-weight: 500;
			}

			.nav-button:hover,
			.nav-button.is-active {
				background: var(--cms-blue-soft);
				color: var(--cms-blue);
			}

			.nav-button span {
				color: var(--cms-muted);
				font-size: 0.8rem;
				font-weight: 500;
			}

			.filter-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
				padding: 0.75rem;
				border-bottom: 1px solid var(--cms-line);
			}

			.filter-button {
				border: 1px solid transparent;
				border-radius: 999px;
				padding: 0.4rem 0.66rem;
				background: #f1f5f9;
				color: var(--cms-muted);
				font-size: 0.86rem;
				font-weight: 500;
			}

			.filter-button.is-active {
				border-color: #c7d2fe;
				background: var(--cms-blue-soft);
				color: var(--cms-blue);
			}

			.post-list {
				display: grid;
				max-height: calc(100vh - 275px);
				overflow: auto;
			}

			.post-button {
				border: 0;
				border-bottom: 1px solid var(--cms-line);
				padding: 0.85rem 1rem;
				background: transparent;
				color: var(--cms-text);
				text-align: left;
			}

			.post-button:hover,
			.post-button.is-active {
				background: #f8faff;
			}

			.post-title {
				display: block;
				font-size: 0.96rem;
				font-weight: 600;
				line-height: 1.35;
			}

			.post-meta {
				display: block;
				margin-top: 0.25rem;
				color: var(--cms-muted);
				font-size: 0.82rem;
				line-height: 1.45;
			}

			.badge {
				display: inline-flex;
				align-items: center;
				width: max-content;
				margin-top: 0.45rem;
				border-radius: 999px;
				padding: 0.15rem 0.5rem;
				background: #e7f8ee;
				color: var(--cms-green);
				font-size: 0.74rem;
				font-weight: 650;
			}

			.badge.is-draft {
				background: #fff2d6;
				color: var(--cms-yellow);
			}

			.editor-toolbar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 1rem 1.1rem;
				border-bottom: 1px solid var(--cms-line);
			}

			.editor-form,
			.category-view {
				display: grid;
				gap: 1rem;
				padding: 1.1rem;
			}

			.field-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
			}

			label {
				display: grid;
				gap: 0.38rem;
				color: var(--cms-dark);
				font-size: 0.9rem;
				font-weight: 600;
			}

			input,
			textarea {
				box-sizing: border-box;
				width: 100%;
				border: 1px solid var(--cms-line);
				border-radius: 9px;
				padding: 0.72rem 0.82rem;
				background: #fff;
				color: var(--cms-text);
				font: inherit;
				font-weight: 400;
			}

			input:focus,
			textarea:focus {
				border-color: #9aa8ff;
				box-shadow: 0 0 0 3px rgba(79, 101, 232, 0.12);
				outline: 0;
			}

			textarea {
				min-height: 430px;
				resize: vertical;
				font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
				font-size: 0.92rem;
				line-height: 1.7;
			}

			.button-row {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.65rem;
			}

			button,
			.file-button {
				border: 0;
				border-radius: 9px;
				padding: 0.68rem 0.9rem;
				background: var(--cms-blue);
				color: #fff;
				font-weight: 600;
			}

			button.secondary,
			.file-button {
				background: var(--cms-dark);
			}

			button.ghost {
				background: transparent;
				color: var(--cms-blue);
			}

			button:disabled {
				opacity: 0.55;
				cursor: not-allowed;
			}

			input[type="file"] {
				display: none;
			}

			.upload-box {
				display: none;
				grid-template-columns: 120px minmax(0, 1fr);
				gap: 1rem;
				align-items: start;
				border: 1px solid var(--cms-line);
				border-radius: 12px;
				padding: 0.85rem;
				background: #f8faff;
			}

			.upload-box.is-visible {
				display: grid;
			}

			.upload-preview {
				aspect-ratio: 4 / 3;
				width: 100%;
				border: 1px solid var(--cms-line);
				border-radius: 10px;
				background: #fff;
				object-fit: cover;
			}

			.status {
				min-height: 1.5rem;
			}

			.status.is-error {
				color: #b42318;
			}

			.category-view[hidden],
			.editor-form[hidden] {
				display: none;
			}

			.category-list {
				display: grid;
				gap: 0.65rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.category-list li {
				display: flex;
				align-items: center;
				justify-content: space-between;
				border: 1px solid var(--cms-line);
				border-radius: 10px;
				padding: 0.75rem 0.85rem;
				background: #fff;
			}

			@media (max-width: 900px) {
				main {
					max-width: calc(100% - 1rem);
					padding: 1rem 0.5rem;
				}

				.admin-shell,
				.field-grid,
				.upload-box {
					grid-template-columns: 1fr;
				}

				.post-list {
					max-height: 300px;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<div class="admin-shell">
				<aside class="admin-panel admin-sidebar">
					<div class="brand-block">
						<h1>CMS Blog</h1>
						<p>Kelola artikel arunajr.com</p>
					</div>
					<nav class="nav-group" aria-label="Menu admin">
						<span class="nav-title">Posts</span>
						<button id="allPostsNav" class="nav-button is-active" type="button">All Posts <span id="postCount">0</span></button>
						<button id="addNewNav" class="nav-button" type="button">Add New</button>
						<button id="categoriesNav" class="nav-button" type="button">Categories <span id="categoryCount">0</span></button>
					</nav>
					<div class="filter-row" aria-label="Filter post">
						<button class="filter-button is-active" type="button" data-filter="all">All</button>
						<button class="filter-button" type="button" data-filter="draft">Draft</button>
						<button class="filter-button" type="button" data-filter="published">Published</button>
					</div>
					<div id="postList" class="post-list" aria-live="polite"></div>
				</aside>

				<section class="admin-panel">
					<div class="editor-toolbar">
						<div>
							<h2 id="editorTitle">Editor Post</h2>
							<p id="editorSubtitle">Tulis, simpan draft, lalu publish saat siap.</p>
						</div>
						<button id="refreshButton" class="ghost" type="button">Refresh</button>
					</div>
					<form id="editorForm" class="editor-form">
						<input id="sha" type="hidden" />
						<input id="status" type="hidden" value="draft" />
						<div class="field-grid">
							<label>
								Judul
								<input id="title" required />
							</label>
							<label>
								Slug
								<input id="slug" required pattern="[a-z0-9-]+" />
							</label>
							<label>
								Tanggal publish
								<input id="pubDate" required placeholder="2026-07-02" />
							</label>
							<label>
								Tanggal update
								<input id="updatedDate" placeholder="2026-07-02" />
							</label>
						</div>
						<div class="field-grid">
							<label>
								Kategori
								<input id="category" list="categoryOptions" placeholder="Uncategorized" />
								<datalist id="categoryOptions"></datalist>
							</label>
							<label>
								Hero image
								<input id="heroImage" placeholder="/foto-profile-ls.webp" />
							</label>
						</div>
						<label>
							Deskripsi
							<input id="description" required />
							<span class="form-hint">Ringkasan pendek untuk SEO dan daftar artikel.</span>
						</label>
						<div class="button-row">
							<label class="file-button" for="imageUpload">Pilih Gambar</label>
							<input id="imageUpload" type="file" accept="image/jpeg,image/png,image/webp" />
							<button id="insertHeadingButton" class="secondary" type="button">Tambah H2</button>
							<button id="insertParagraphButton" class="secondary" type="button">Tambah Paragraf</button>
						</div>
						<div id="uploadBox" class="upload-box">
							<img id="imagePreview" class="upload-preview" alt="Preview gambar yang dipilih" />
							<div>
								<label>
									Slug file gambar
									<input id="imageFileSlug" pattern="[a-z0-9-]+" />
								</label>
								<p id="uploadMeta" class="upload-meta"></p>
								<div class="button-row" style="margin-top: 0.75rem;">
									<button id="uploadButton" type="button">Upload Gambar</button>
									<button id="clearImageButton" class="ghost" type="button">Batal</button>
								</div>
							</div>
						</div>
						<label>
							Isi artikel
							<textarea id="body" required></textarea>
						</label>
						<div class="button-row">
							<button id="draftButton" type="button">Save Draft</button>
							<button id="publishButton" type="submit">Publish</button>
							<button id="previewButton" class="secondary" type="button">Preview di Tab Baru</button>
							<p id="statusMessage" class="status"></p>
						</div>
					</form>
					<section id="categoryView" class="category-view" hidden>
						<div>
							<h2 style="margin:0;font-size:1.25rem;">Categories</h2>
							<p class="form-hint">Kategori dibuat otomatis dari field kategori di setiap post.</p>
						</div>
						<ul id="categoryList" class="category-list"></ul>
					</section>
				</section>
			</div>
		</main>

		<script>
			const API_BASE = "/admin/api";
			const PREVIEW_STORAGE_KEY = "arunajr-cms-preview-post";

			const state = {
				posts: [],
				currentSlug: "",
				isNew: true,
				filter: "all",
				nextStatus: "published",
				selectedImageUrl: "",
			};

			const elements = {
				postList: document.getElementById("postList"),
				postCount: document.getElementById("postCount"),
				categoryCount: document.getElementById("categoryCount"),
				allPostsNav: document.getElementById("allPostsNav"),
				addNewNav: document.getElementById("addNewNav"),
				categoriesNav: document.getElementById("categoriesNav"),
				refreshButton: document.getElementById("refreshButton"),
				editorForm: document.getElementById("editorForm"),
				categoryView: document.getElementById("categoryView"),
				categoryList: document.getElementById("categoryList"),
				categoryOptions: document.getElementById("categoryOptions"),
				editorTitle: document.getElementById("editorTitle"),
				editorSubtitle: document.getElementById("editorSubtitle"),
				status: document.getElementById("status"),
				statusMessage: document.getElementById("statusMessage"),
				sha: document.getElementById("sha"),
				title: document.getElementById("title"),
				slug: document.getElementById("slug"),
				pubDate: document.getElementById("pubDate"),
				updatedDate: document.getElementById("updatedDate"),
				category: document.getElementById("category"),
				description: document.getElementById("description"),
				heroImage: document.getElementById("heroImage"),
				body: document.getElementById("body"),
				imageUpload: document.getElementById("imageUpload"),
				uploadBox: document.getElementById("uploadBox"),
				imagePreview: document.getElementById("imagePreview"),
				imageFileSlug: document.getElementById("imageFileSlug"),
				uploadMeta: document.getElementById("uploadMeta"),
				uploadButton: document.getElementById("uploadButton"),
				clearImageButton: document.getElementById("clearImageButton"),
				insertHeadingButton: document.getElementById("insertHeadingButton"),
				insertParagraphButton: document.getElementById("insertParagraphButton"),
				previewButton: document.getElementById("previewButton"),
				draftButton: document.getElementById("draftButton"),
				publishButton: document.getElementById("publishButton"),
				filterButtons: document.querySelectorAll("[data-filter]"),
			};

			elements.allPostsNav.addEventListener("click", () => showEditor());
			elements.addNewNav.addEventListener("click", () => newPost());
			elements.categoriesNav.addEventListener("click", () => showCategories());
			elements.refreshButton.addEventListener("click", () => loadPosts());
			elements.editorForm.addEventListener("submit", (event) => savePost(event));
			elements.draftButton.addEventListener("click", () => saveDraft());
			elements.previewButton.addEventListener("click", () => openPreview());
			elements.imageUpload.addEventListener("change", () => prepareImageUpload());
			elements.uploadButton.addEventListener("click", () => uploadImage());
			elements.clearImageButton.addEventListener("click", () => clearSelectedImage());
			elements.insertHeadingButton.addEventListener("click", () => insertText("\\n<h2>Judul Bagian</h2>\\n"));
			elements.insertParagraphButton.addEventListener("click", () => insertText("\\n<p>Isi paragraf.</p>\\n"));
			elements.title.addEventListener("input", () => {
				if (state.isNew) elements.slug.value = slugify(elements.title.value);
			});
			elements.filterButtons.forEach((button) => {
				button.addEventListener("click", () => {
					state.filter = button.dataset.filter;
					renderPostList();
				});
			});

			loadPosts();
			newPost();

			async function loadPosts() {
				try {
					setStatus("Memuat daftar post...");
					const data = await requestJson(`${API_BASE}/posts`);
					state.posts = data.posts || [];
					renderPostList();
					renderCategories();
					setStatus("Daftar post siap.");
				} catch (error) {
					setStatus(error.message, true);
				}
			}

			function renderPostList() {
				elements.postList.innerHTML = "";
				elements.postCount.textContent = String(state.posts.length);
				elements.filterButtons.forEach((button) => {
					button.classList.toggle("is-active", button.dataset.filter === state.filter);
				});

				const filteredPosts = state.posts.filter((post) => {
					return state.filter === "all" || post.status === state.filter;
				});

				for (const post of filteredPosts) {
					const button = document.createElement("button");
					button.type = "button";
					button.className = `post-button${post.slug === state.currentSlug ? " is-active" : ""}`;
					const badgeClass = post.status === "draft" ? "badge is-draft" : "badge";
					button.innerHTML = `
						<span class="post-title">${escapeHtml(post.title)}</span>
						<span class="post-meta">${escapeHtml(post.pubDate)} · ${escapeHtml(post.category || "Uncategorized")} · ${escapeHtml(post.slug)}</span>
						<span class="${badgeClass}">${escapeHtml(post.status)}</span>
					`;
					button.addEventListener("click", () => loadPost(post.slug));
					elements.postList.append(button);
				}

				if (filteredPosts.length === 0) {
					const empty = document.createElement("div");
					empty.className = "post-button";
					empty.textContent = "Tidak ada post untuk filter ini.";
					elements.postList.append(empty);
				}
			}

			function renderCategories() {
				const categories = categoryStats();
				elements.categoryCount.textContent = String(categories.length);
				elements.categoryOptions.innerHTML = "";
				elements.categoryList.innerHTML = "";

				for (const category of categories) {
					const option = document.createElement("option");
					option.value = category.name;
					elements.categoryOptions.append(option);

					const item = document.createElement("li");
					item.innerHTML = `<span>${escapeHtml(category.name)}</span><span class="post-meta">${category.count} post</span>`;
					elements.categoryList.append(item);
				}
			}

			function categoryStats() {
				const counts = new Map();
				for (const post of state.posts) {
					const category = post.category || "Uncategorized";
					counts.set(category, (counts.get(category) || 0) + 1);
				}
				if (counts.size === 0) counts.set("Uncategorized", 0);
				return [...counts.entries()]
					.map(([name, count]) => ({ name, count }))
					.sort((a, b) => a.name.localeCompare(b.name));
			}

			async function loadPost(slug) {
				try {
					showEditor();
					setStatus("Memuat post...");
					const data = await requestJson(`${API_BASE}/posts/${encodeURIComponent(slug)}`);
					fillForm(data.post, false);
					setStatus("Post siap diedit.");
				} catch (error) {
					setStatus(error.message, true);
				}
			}

			function newPost() {
				showEditor();
				fillForm(
					{
						slug: "",
						title: "",
						description: "",
						pubDate: new Date().toISOString().slice(0, 10),
						updatedDate: "",
						category: "Uncategorized",
						heroImage: "",
						body: "<h2>Judul Bagian</h2>\\n\\n<p>Tulis artikel di sini.</p>",
						status: "draft",
						sha: "",
					},
					true,
				);
				setStatus("Post baru siap diisi.");
			}

			function fillForm(post, isNew) {
				state.currentSlug = post.slug || "";
				state.isNew = isNew;
				elements.editorTitle.textContent = isNew ? "Add New Post" : "Edit Post";
				elements.editorSubtitle.textContent = isNew
					? "Tulis draft baru, lalu publish saat siap."
					: `Sedang mengedit: ${post.slug}`;
				elements.sha.value = post.sha || "";
				elements.status.value = post.status || "published";
				elements.title.value = post.title || "";
				elements.slug.value = post.slug || "";
				elements.slug.disabled = !isNew;
				elements.pubDate.value = post.pubDate || "";
				elements.updatedDate.value = post.updatedDate || "";
				elements.category.value = post.category || "Uncategorized";
				elements.description.value = post.description || "";
				elements.heroImage.value = post.heroImage || "";
				elements.body.value = post.body || "";
				clearSelectedImage();
				renderPostList();
			}

			function showEditor() {
				elements.editorForm.hidden = false;
				elements.categoryView.hidden = true;
				elements.allPostsNav.classList.add("is-active");
				elements.addNewNav.classList.toggle("is-active", state.isNew);
				elements.categoriesNav.classList.remove("is-active");
			}

			function showCategories() {
				elements.editorForm.hidden = true;
				elements.categoryView.hidden = false;
				elements.allPostsNav.classList.remove("is-active");
				elements.addNewNav.classList.remove("is-active");
				elements.categoriesNav.classList.add("is-active");
			}

			async function savePost(event) {
				event.preventDefault();
				state.nextStatus = "published";
				await submitPost();
			}

			async function saveDraft() {
				state.nextStatus = "draft";
				await submitPost();
			}

			async function submitPost() {
				elements.draftButton.disabled = true;
				elements.publishButton.disabled = true;
				setStatus(state.nextStatus === "draft" ? "Menyimpan draft..." : "Publish ke GitHub...");

				try {
					const payload = formPayload();
					payload.status = state.nextStatus;
					const url = state.isNew
						? `${API_BASE}/posts`
						: `${API_BASE}/posts/${encodeURIComponent(state.currentSlug)}`;
					const method = state.isNew ? "POST" : "PUT";
					const data = await requestJson(url, {
						method,
						headers: { "content-type": "application/json" },
						body: JSON.stringify(payload),
					});
					fillForm(data.post, false);
					await loadPosts();
					setStatus(
						state.nextStatus === "draft"
							? "Draft tersimpan. Artikel tidak tampil publik."
							: "Published. Deploy otomatis akan berjalan dari GitHub.",
					);
				} catch (error) {
					setStatus(error.message, true);
				} finally {
					elements.draftButton.disabled = false;
					elements.publishButton.disabled = false;
				}
			}

			function prepareImageUpload() {
				const file = elements.imageUpload.files[0];
				if (!file) {
					clearSelectedImage();
					return;
				}

				if (state.selectedImageUrl) URL.revokeObjectURL(state.selectedImageUrl);
				state.selectedImageUrl = URL.createObjectURL(file);
				elements.imagePreview.src = state.selectedImageUrl;
				elements.imageFileSlug.value = slugify(file.name.replace(/\.[^.]+$/, "")) || "image";
				elements.uploadMeta.textContent = `${file.name} · ${formatBytes(file.size)}`;
				elements.uploadBox.classList.add("is-visible");
				setStatus("Gambar siap diupload. Cek thumbnail dan slug file dulu.");
			}

			async function uploadImage() {
				const file = elements.imageUpload.files[0];
				if (!file) return;

				const formData = new FormData();
				formData.set("file", file);
				formData.set("slug", elements.imageFileSlug.value);
				elements.uploadButton.disabled = true;
				setStatus("Mengupload gambar...");

				try {
					const data = await requestJson(`${API_BASE}/uploads`, {
						method: "POST",
						body: formData,
					});
					elements.heroImage.value = data.upload.path;
					insertText(`\\n<img src="${data.upload.path}" alt="">\\n`);
					clearSelectedImage();
					setStatus("Gambar berhasil diupload dan path hero image sudah diperbarui.");
				} catch (error) {
					setStatus(error.message, true);
				} finally {
					elements.uploadButton.disabled = false;
				}
			}

			function clearSelectedImage() {
				if (state.selectedImageUrl) URL.revokeObjectURL(state.selectedImageUrl);
				state.selectedImageUrl = "";
				elements.imageUpload.value = "";
				elements.imagePreview.removeAttribute("src");
				elements.imageFileSlug.value = "";
				elements.uploadMeta.textContent = "";
				elements.uploadBox.classList.remove("is-visible");
			}

			function formPayload() {
				return {
					sha: elements.sha.value,
					title: elements.title.value,
					slug: elements.slug.value,
					description: elements.description.value,
					pubDate: elements.pubDate.value,
					updatedDate: elements.updatedDate.value,
					category: elements.category.value || "Uncategorized",
					heroImage: elements.heroImage.value,
					status: elements.status.value || "draft",
					body: elements.body.value,
				};
			}

			function openPreview() {
				localStorage.setItem(PREVIEW_STORAGE_KEY, JSON.stringify(formPayload()));
				window.open("/admin/preview", "_blank", "noopener");
			}

			function insertText(text) {
				const start = elements.body.selectionStart;
				const end = elements.body.selectionEnd;
				const current = elements.body.value;
				elements.body.value = `${current.slice(0, start)}${text}${current.slice(end)}`;
				elements.body.focus();
				elements.body.selectionStart = start + text.length;
				elements.body.selectionEnd = start + text.length;
			}

			async function requestJson(url, options) {
				let response;
				try {
					response = await fetch(url, {
						credentials: "same-origin",
						...options,
					});
				} catch {
					throw new Error("Gagal terhubung ke CMS. Coba refresh halaman admin.");
				}

				const data = await response.json().catch(() => ({}));
				if (!response.ok) {
					throw new Error(data.error || "Request CMS gagal. Coba login ulang ke admin.");
				}
				return data;
			}

			function setStatus(message, isError = false) {
				elements.statusMessage.textContent = message;
				elements.statusMessage.classList.toggle("is-error", isError);
			}

			function slugify(value) {
				return value
					.toLowerCase()
					.normalize("NFKD")
					.replace(/[\\u0300-\\u036f]/g, "")
					.replace(/[^a-z0-9]+/g, "-")
					.replace(/^-+|-+$/g, "");
			}

			function formatBytes(bytes) {
				if (bytes < 1024) return `${bytes} B`;
				if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
				return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
			}

			function escapeHtml(value) {
				return String(value || "")
					.replace(/&/g, "&amp;")
					.replace(/</g, "&lt;")
					.replace(/>/g, "&gt;")
					.replace(/"/g, "&quot;");
			}
		</script>
	</body>
</html>
