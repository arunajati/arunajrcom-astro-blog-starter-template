---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="All Posts" active="posts">
	<div class="page-header">
		<div>
			<h2>All Posts</h2>
			<p class="page-subtitle">Daftar artikel untuk edit, cek status, dan publish workflow.</p>
		</div>
		<a class="button primary" href="/admin/posts/new">Add New Post</a>
	</div>

	<div class="posts-page">
		<div class="toolbar">
			<div class="filter-row" aria-label="Filter post">
				<button class="filter-button is-active" type="button" data-filter="all">All</button>
				<button class="filter-button" type="button" data-filter="draft">Draft</button>
				<button class="filter-button" type="button" data-filter="published">Published</button>
			</div>
			<button id="refreshButton" class="ghost compact" type="button">Refresh</button>
		</div>
		<p id="statusMessage" class="status">Memuat daftar post...</p>
		<div class="table-wrap">
			<table>
				<thead>
					<tr>
						<th>Title</th>
						<th>Status</th>
						<th>Publish Date</th>
						<th></th>
					</tr>
				</thead>
				<tbody id="postRows"></tbody>
			</table>
		</div>
		<div class="load-more-row">
			<button id="loadMoreButton" class="ghost compact load-more-button" type="button" hidden>Load more</button>
		</div>
	</div>

	<style>
		:global(.posts-page) {
			display: grid;
			gap: 1.25rem;
			padding: 1.5rem;
		}

		:global(.toolbar) {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 1rem;
		}

		:global(.filter-row) {
			display: flex;
			flex-wrap: wrap;
			gap: 0.45rem;
		}

		:global(.filter-button) {
			border: 1px solid transparent;
			border-radius: 999px;
			padding: 0.34rem 0.58rem;
			background: #f1f5f9;
			color: var(--cms-muted);
			font-size: 0.82rem;
			font-weight: 500;
			box-shadow: none;
		}

		:global(.filter-button.is-active) {
			border-color: #c7d2fe;
			background: var(--cms-blue-soft);
			color: var(--cms-blue);
		}

		:global(.table-wrap) {
			overflow: auto;
			border: 1px solid var(--cms-line);
			border-radius: 12px;
		}

		:global(table) {
			table-layout: fixed;
			width: 100%;
			border-collapse: collapse;
			min-width: 680px;
		}

		:global(th:first-child),
		:global(td:first-child) {
			width: 62%;
		}

		:global(th:nth-child(2)),
		:global(td:nth-child(2)) {
			width: 120px;
		}

		:global(th:nth-child(3)),
		:global(td:nth-child(3)) {
			width: 120px;
		}

		:global(th:last-child),
		:global(td:last-child) {
			width: 160px;
			text-align: right;
		}

		:global(th),
		:global(td) {
			border-bottom: 1px solid var(--cms-line);
			padding: 0.95rem 1rem;
			text-align: left;
			vertical-align: middle;
		}

		:global(th) {
			background: #f8faff;
			color: var(--cms-muted);
			font-size: 0.78rem;
			font-weight: 650;
			letter-spacing: 0.04em;
			text-transform: uppercase;
		}

		:global(tr:last-child td) {
			border-bottom: 0;
		}

		:global(.post-title) {
			display: block;
			color: var(--cms-text);
			font-weight: 600;
			line-height: 1.35;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}

		:global(.row-description) {
			display: block;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}

		:global(.row-actions) {
			display: inline-flex;
			justify-content: flex-end;
			gap: 0.45rem;
		}

		:global(.danger) {
			background: #fee2e2;
			color: var(--cms-red);
			box-shadow: none;
		}

		:global(.load-more-row) {
			display: flex;
			justify-content: center;
			padding-top: 0.1rem;
		}

		:global(.load-more-button) {
			min-width: 168px;
			padding-inline: 1rem;
			border-color: #c7d2fe;
			background: #fff;
			color: var(--cms-blue);
			box-shadow: none;
		}

		:global(.load-more-button:hover) {
			background: var(--cms-blue-soft);
		}

		@media (max-width: 720px) {
			.toolbar,
			:global(.page-header) {
				align-items: flex-start;
				flex-direction: column;
			}
		}
	</style>

	<script>
		const API_BASE = "/admin/api";
		const PAGE_SIZE = 10;
		const state = {
			posts: [],
			filter: "all",
			visibleCount: PAGE_SIZE,
		};

		const rows = document.getElementById("postRows");
		const statusMessage = document.getElementById("statusMessage");
		const refreshButton = document.getElementById("refreshButton");
		const loadMoreButton = document.getElementById("loadMoreButton");
		const filterButtons = document.querySelectorAll("[data-filter]");

		refreshButton.addEventListener("click", () => loadPosts());
		rows.addEventListener("click", (event) => handlePostAction(event));
		loadMoreButton.addEventListener("click", () => {
			state.visibleCount += PAGE_SIZE;
			renderPosts();
		});
		filterButtons.forEach((button) => {
			button.addEventListener("click", () => {
				state.filter = button.dataset.filter;
				state.visibleCount = PAGE_SIZE;
				renderPosts();
			});
		});

		loadPosts();

		async function loadPosts() {
			try {
				setStatus("Memuat daftar post...");
				const data = await requestJson(`${API_BASE}/posts`);
				state.posts = data.posts || [];
				state.visibleCount = PAGE_SIZE;
				renderPosts();
				setStatus(`${state.posts.length} post siap dikelola.`);
			} catch (error) {
				setStatus(error.message, true);
			}
		}

		function renderPosts() {
			rows.innerHTML = "";
			filterButtons.forEach((button) => {
				button.classList.toggle("is-active", button.dataset.filter === state.filter);
			});

			const posts = state.posts.filter((post) => state.filter === "all" || post.status === state.filter);
			const visiblePosts = posts.slice(0, state.visibleCount);
			for (const post of visiblePosts) {
				const tr = document.createElement("tr");
				const badgeClass = post.status === "draft" ? "badge is-draft" : "badge";
				tr.innerHTML = `
					<td>
						<span class="post-title">${escapeHtml(post.title)}</span>
						<span class="post-meta row-description">${escapeHtml(post.description || "")}</span>
					</td>
					<td><span class="${badgeClass}">${escapeHtml(post.status)}</span></td>
					<td>${formatShortDate(post.pubDate)}</td>
					<td>
						<span class="row-actions">
							<a class="button secondary compact" href="/admin/posts/edit?slug=${encodeURIComponent(post.slug)}">Edit</a>
							<button class="danger compact" type="button" data-action="delete" data-slug="${escapeHtml(post.slug)}" data-title="${escapeHtml(post.title)}">Delete</button>
						</span>
					</td>
				`;
				rows.append(tr);
			}

			if (posts.length === 0) {
				const tr = document.createElement("tr");
				tr.innerHTML = `<td colspan="4">Tidak ada post untuk filter ini.</td>`;
				rows.append(tr);
			}

			const hasMore = posts.length > visiblePosts.length;
			loadMoreButton.hidden = !hasMore;
			loadMoreButton.textContent = hasMore
				? `Load more (${posts.length - visiblePosts.length} left)`
				: "Load more";
		}

		async function handlePostAction(event) {
			const button = event.target.closest("[data-action='delete']");
			if (!button) return;

			const slug = button.dataset.slug || "";
			const title = button.dataset.title || slug;
			if (!window.confirm(`Hapus post "${title}" dan gambar yang hanya dipakai post ini?`)) return;

			button.disabled = true;
			try {
				setStatus("Menghapus post...");
				const data = await requestJson(`${API_BASE}/posts/${encodeURIComponent(slug)}`, {
					method: "DELETE",
				});
				state.posts = state.posts.filter((post) => post.slug !== slug);
				renderPosts();
				setStatus(`Post dihapus. ${data.removedImages || 0} gambar unik ikut dibersihkan.`);
			} catch (error) {
				setStatus(error.message, true);
			} finally {
				button.disabled = false;
			}
		}

		function formatShortDate(value) {
			const date = new Date(value);
			if (Number.isNaN(date.valueOf())) return escapeHtml(value);
			const parts = new Intl.DateTimeFormat("en-GB", {
				day: "2-digit",
				month: "2-digit",
				year: "2-digit",
				timeZone: "Asia/Jakarta",
			}).formatToParts(date);
			const day = parts.find((part) => part.type === "day")?.value || "";
			const month = parts.find((part) => part.type === "month")?.value || "";
			const year = parts.find((part) => part.type === "year")?.value || "";
			return `${day}/${month}/${year}`;
		}

		async function requestJson(url, options) {
			let response;
			try {
				response = await fetch(url, { credentials: "same-origin", ...options });
			} catch {
				throw new Error("Gagal terhubung ke CMS. Coba refresh halaman admin.");
			}

			const data = await response.json().catch(() => ({}));
			if (!response.ok) throw new Error(data.error || "Request CMS gagal. Coba login ulang ke admin.");
			return data;
		}

		function setStatus(message, isError = false) {
			statusMessage.textContent = message;
			statusMessage.classList.toggle("is-error", isError);
		}

		function escapeHtml(value) {
			return String(value || "")
				.replace(/&/g, "&amp;")
				.replace(/</g, "&lt;")
				.replace(/>/g, "&gt;")
				.replace(/"/g, "&quot;");
		}
	</script>
</AdminLayout>
