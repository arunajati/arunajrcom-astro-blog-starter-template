{
	"name": "arunajrcom-astro-blog-starter-template",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"vars": {
		"CMS_GITHUB_OWNER": "arunajati",
		"CMS_GITHUB_REPO": "arunajrcom-astro-blog-starter-template",
		"CMS_GITHUB_BRANCH": "main"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}
